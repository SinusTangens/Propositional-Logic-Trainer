                </mxCell>
                <mxCell id="53" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Informationsgehalt für &#39;var&#39; wird auf die anderen Dimensionen projeziert (=Dimensionsreduktion durch logisches &quot;ODER&quot;)&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="31" vertex="1">
                    <mxGeometry x="126.66" y="560" width="180" height="80" as="geometry"/>
                </mxCell>
                <mxCell id="54" value="&lt;span style=&quot;color: rgb(63, 63, 63); font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif; text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;AND(T1, ..., Ti)⁻⁽&#39;ᵛᵃʳ&#39;⁾&lt;/font&gt;&lt;/span&gt;" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;" parent="31" vertex="1">
                    <mxGeometry x="166.67000000000002" y="640" width="100" height="40" as="geometry"/>
                </mxCell>
                <mxCell id="56" value="" style="rounded=0;whiteSpace=wrap;html=1;" parent="31" vertex="1">
                    <mxGeometry x="60" y="370" width="170" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="57" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;Tabelle wird abgespeichert, wenn sie nicht nur aus 1en oder wenn sie nur aus 0en besteht. Sichert Informationsgehalt für folgende Schleifendurchläufe&amp;nbsp;&amp;nbsp;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;" parent="31" vertex="1">
                    <mxGeometry x="70" y="395" width="141.66" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="55" value="&lt;div class=&quot;math-block&quot; data-math=&quot;\text{AND}(T_1, \dots, T_i)^{-\text{&#39;var&#39;}}&quot; style=&quot;font-family: &amp;quot;Google Sans Text&amp;quot;, sans-serif !important; line-height: 1.15 !important; margin-top: 0px !important;&quot;&gt;&lt;br&gt;&lt;/div&gt;" style="text;whiteSpace=wrap;html=1;" parent="1" vertex="1">
                    <mxGeometry x="-420" y="1830" width="270" height="40" as="geometry"/>
                </mxCell>
                <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TD\n    %% --- STYLES ---\n    classDef data fill:#dae8fc,stroke:#6c8ebf,stroke-width:2px;\n    classDef process fill:#fff2cc,stroke:#d6b656,stroke-width:2px,rx:5,ry:5;\n    classDef storage fill:#f5f5f5,stroke:#666666,stroke-width:2px;\n    classDef decision fill:#e1d5e7,stroke:#9673a6,stroke-width:2px;\n\n    %% --- PHASE 1 ---\n    subgraph P1 [\&quot;Phase 1: Initialisierung\&quot;]\n        TaskObj[\&quot;Input: Task Objekt (SymPy Formeln)\&quot;]:::data\n        IterPrem[\&quot;1. Iteriere ueber Praemissen\&quot;]:::process\n        CreateArray[\&quot;2. Erstelle leeres Numpy Array (Shape: 2^n)\&quot;]:::process\n        FillTruth[\&quot;3. Befuelle Tabelle mit Wahrheitswerten\&quot;]:::process\n        \n        TaskObj --&gt; IterPrem\n        IterPrem --&gt; CreateArray\n        CreateArray --&gt; FillTruth\n    end\n\n    TablesList[(\&quot;self.tables (Liste)\&quot;)]:::storage\n    FillTruth --&gt; TablesList\n\n    %% --- PHASE 2 ---\n    subgraph P2 [\&quot;Phase 2: Forward Pass - solve\&quot;]\n        CurrentTables[\&quot;current_tables (Arbeitskopie)\&quot;]:::data\n        TablesList --&gt; CurrentTables\n        \n        VarSelect{\&quot;Fuer jede Variable\&quot;}:::decision\n        CurrentTables --&gt; VarSelect\n        \n        BuildBucket[\&quot;Bucket bilden (Filtere Tabellen)\&quot;]:::process\n        VarSelect --&gt; BuildBucket\n        \n        SplitTables{\&quot;Ist Variable enthalten?\&quot;}:::decision\n        BuildBucket --&gt; SplitTables\n        \n        BucketList[\&quot;Bucket (Tabellen MIT Var)\&quot;]:::data\n        RestList[\&quot;other_tables (Tabellen OHNE Var)\&quot;]:::data\n        \n        SplitTables -- Ja --&gt; BucketList\n        SplitTables -- Nein --&gt; RestList\n        \n        SaveHist[(\&quot;self.history_buckets\&quot;)]:::storage\n        BucketList --&gt; SaveHist\n        \n        CombineOp[\&quot;COMBINE (Logisches UND)\&quot;]:::process\n        BucketList --&gt; CombineOp\n        \n        MargOp[\&quot;MARGINALIZE (Logisches ODER)\&quot;]:::process\n        CombineOp --&gt; MargOp\n        \n        NewTable[\&quot;Neue Tabelle\&quot;]:::data\n        MargOp --&gt; NewTable\n        \n        UpdateList[\&quot;Update current_tables\&quot;]:::process\n        RestList --&gt; UpdateList\n        NewTable --&gt; UpdateList\n        UpdateList --&gt; VarSelect\n\n        CheckConsist{\&quot;Pruefung: final_consistency\&quot;}:::decision\n        VarSelect -- Fertig --&gt; CheckConsist\n        \n        SolvedTrue[\&quot;TRUE (Constraints aufgeloest)\&quot;]:::data\n        SolvedFalse[\&quot;FALSE (Widerspruch)\&quot;]:::data\n        \n        CheckConsist -- Liste leer --&gt; SolvedTrue\n        CheckConsist -- Liste voll --&gt; CheckRest{\&quot;Enthaelt True?\&quot;}:::decision\n        CheckRest -- Ja --&gt; SolvedTrue\n        CheckRest -- Nein --&gt; SolvedFalse\n    end\n\n    %% --- PHASE 3 ---\n    subgraph P3 [\&quot;Phase 3: Backward Pass - get_solution\&quot;]\n        SolutionDict[(\&quot;solution Dict\&quot;)]:::storage\n        SolvedTrue --&gt; SolutionDict\n        \n        BackVar{\&quot;Fuer jede Var rueckwaerts\&quot;}:::decision\n        SolutionDict --&gt; BackVar\n        \n        LoadHist[\&quot;Lade Bucket aus History\&quot;]:::process\n        BackVar --&gt; LoadHist\n        \n        CombineHist[\&quot;COMBINE Bucket\&quot;]:::process\n        LoadHist --&gt; CombineHist\n        \n        ConditionOp[\&quot;CONDITION (Slicing mit bekannten Werten)\&quot;]:::process\n        CombineHist --&gt; ConditionOp\n        \n        TestTrue[\&quot;Test: Var=True moeglich?\&quot;]:::process\n        TestFalse[\&quot;Test: Var=False moeglich?\&quot;]:::process\n        ConditionOp --&gt; TestTrue\n        ConditionOp --&gt; TestFalse\n        \n        Decide{\&quot;Ergebnis\&quot;}:::decision\n        TestTrue --&gt; Decide\n        TestFalse --&gt; Decide\n        \n        AssignTrue[\&quot;Setze Var = True\&quot;]:::process\n        AssignFalse[\&quot;Setze Var = False\&quot;]:::process\n        AssignNone[\&quot;Setze Var = None\&quot;]:::process\n        \n        Decide -- Nur True --&gt; AssignTrue\n        Decide -- Nur False --&gt; AssignFalse\n        Decide -- Beides --&gt; AssignNone\n        \n        AssignTrue --&gt; SolutionDict\n        AssignFalse --&gt; SolutionDict\n        AssignNone --&gt; SolutionDict\n    end\n\n    FinalOutput((\&quot;Ausgabe\&quot;)):::data\n    SolutionDict --&gt; FinalOutput&quot;&#xa;}" id="59">
                    <mxCell style="shape=image;noLabel=1;verticalAlign=top;imageAspect=1;image=data:image/svg+xml,;" vertex="1" parent="1">
                        <mxGeometry x="420" y="-920" width="2696.22607421875" height="3060.48388671875" as="geometry"/>
                    </mxCell>
                </UserObject>
            </root>
        </mxGraphModel>
