                <mxCell id="49" value="&lt;font style=&quot;font-size: 10px;&quot;&gt;AND(T1, ..., Ti)&lt;/font&gt;" style="shape=cylinder;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;" parent="31" vertex="1">
                    <mxGeometry x="496.67" y="640" width="73.33" height="40" as="geometry"/>
                </mxCell>
